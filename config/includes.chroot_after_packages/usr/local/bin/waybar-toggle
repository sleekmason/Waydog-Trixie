#!/bin/bash
# Waybar toggle for labwc, sway, and niri.
# Made by sleekmason for waydog.

if pgrep -x waybar > /dev/null; then
    pkill -x waybar
    pkill -x nm-applet
    exit 0
fi

if pgrep -x sway > /dev/null; then
    waybar -c "$HOME/.config/waybar/sway/config.jsonc" &
elif pgrep -x niri > /dev/null; then
    waybar -c "$HOME/.config/waybar/niri/config.jsonc" &
elif pgrep -x mango > /dev/null; then
    waybar -c "$HOME/.config/waybar/mango/config.jsonc" &    
else
    waybar &
fi

nm-applet &
