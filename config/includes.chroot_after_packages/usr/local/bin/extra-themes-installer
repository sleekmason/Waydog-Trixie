#!/bin/bash
read -p "   [0;33mExtra Themes Installer[0m

   This script will download and install a selection of themes to
   include GTK, Openbox(labwc), and Geany. Labwc menu theming can
   be changed in ~/.config/labwc/themerc-override.
    
   The matching menu colors for any of the themes can be found in
   their respective *box folders located in /usr/share/themes.
      
   There are currently 14 themes for this installer.
      
   [0;32m--------------------------------------------------------------
   
   Please press enter to install the extra themes.
   
   --------------------------------------------------------------[0m
      
   Or, close this terminal window to quit the install." ;
   if : >/dev/tcp/8.8.8.8/53; then
echo ""
cd /tmp || exit &&

# Remove copies from /tmp
sudo rm -fr "/tmp/themechooser"
sudo rm -fr "/tmp/themechooser-waydog.zip"

# Grab the theme files
wget --prefer-family=IPv4 https://raw.githubusercontent.com/sleekmason/packages/master/themechooser-waydog.zip --show-progress -q
unzip -q "/tmp/themechooser-waydog.zip"

sudo cp -af /tmp/themechooser/themes/* "/usr/share/themes"

sudo cp -af /tmp/themechooser/geany/* "/usr/share/geany"

echo ""
echo "   [0;33m----------------------------------------------------------------------"
echo ""
echo "   All Finished!"
echo "" 
echo "   ----------------------------------------------------------------------[0m"
else
echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
 echo ""
 echo "   [0;33mNo Internet connection. Please connect and try again.[0m"
 echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
echo ""
fi
read -n1 -p "   Press any key to quit this dialog ... "
