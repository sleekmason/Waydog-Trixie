#!/bin/bash
echo ""
read -p "   [0;33mMissing Firmware Installer[0m

   This script will install a tiny program isenkram-cli to check if
   firmware is missing, and if so, install the necessary packages.
   
   [0;32m----------------------------------------------------------------
   
   Please press enter to install or re-run isenkram-cli.
   
   ----------------------------------------------------------------[0m
      
   Or close this terminal window to quit the install." ;
   if : >/dev/tcp/8.8.8.8/53; then
echo ""
sudo apt update && sudo apt install -y isenkram-cli &&
echo "[0;32m------------------------------------------------------------------[0m"
echo ""
sudo isenkram-autoinstall-firmware
echo ""
echo ""
echo " [0;34m------------------------------------------------------------------[0m"
echo ""
echo " [0;34mFinished! Please see above for information about your firmware.[0m"
echo ""
echo " [0;34m------------------------------------------------------------------[0m"
echo ""
else
echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
 echo ""
 echo "   [0;33mNo Internet connection. Please connect and try again.[0m"
 echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
echo ""
fi
read -n1 -p " Press any key to quit this dialog ... "
