#!/bin/bash
read -p "   [0;33mSnap Installer[0m

   This will install Snapd and the Snap App Store, the app store 
   for Linux.
   
   Please note that the installation can take a while for a slow
   connection as snap searches for resources. About 7 minutes on
   a fairly decent connection here.
   
   [0;34mhttps://snapcraft.io/[0m
   
   [0;32m-------------------------------------------------------------
   
   Please press enter to install Snap.
   
   -------------------------------------------------------------[0m  
   
   Or, close this terminal window to quit the install." ;
   
if [ -e /run/live/medium ] || [ -e /lib/live/mount ] || \
   findmnt -n -o FSTYPE / | grep -Eq 'overlay|squashfs'; then
    echo ""
    echo "   [0;31m-------------------------------------------------------------[0m"
    echo ""
    echo "   [0;33mLive environment detected.[0m"
    echo ""
    echo "   [0;33mInstallation of Snap in a live environment is not supported.[0m"
    echo ""
    echo "   [0;31m-------------------------------------------------------------[0m"
    echo ""
    read -n1 -p " Press any key to quit this dialog ... "
    exit 0
fi
sudo apt-get update
sudo apt-get install -y snapd
echo "  [0;32mEnabling snapd service...[0m"
sudo systemctl enable --now snapd.socket
sudo systemctl enable --now snapd.service
sudo systemctl restart snapd
echo -n "  [0;32mWaiting for snapd to become ready...[0m"
echo ""
for i in {1..60}; do
    if snap version >/dev/null 2>&1; then
        echo "  [0;34mdone![0m"
        echo ""
        break
    fi
    sleep 2
done

if ! snap version >/dev/null 2>&1; then
    echo ""
    echo "  [0;31mSnapd failed to start after waiting.[0m"
    read -n1 -p " Press any key to quit this dialog... "
    exit 1
fi
sudo snap install snapd >/dev/null
sudo snap install core >/dev/null
sudo snap refresh core >/dev/null
echo ""
echo "  [0;32mInstalling the Snap Store... This can take a while.[0m"
echo ""
if ! sudo snap install snap-store; then
    echo "  [0;33msnap-store requires the user-daemons feature — enabling it...[0m"
    sudo snap set system experimental.user-daemons=true
    echo "  [0;33mRetrying Snap Store install...[0m"
    if ! sudo snap install snap-store; then
        echo ""
        echo "  [0;31mSnap installation failed even after enabling user-daemons.[0m"
        echo "  [0;31mPlease check network/DNS and try again.[0m"
        read -n1 -p " Press any key to quit this dialog ... "
        exit 1
    fi
fi
echo ""
echo "  [0;32m--------------------------------------------------------------"
echo ""
echo "  All finished! For menus other than Wmenu, logging out and back"
echo "  in will be necessary for the App Center to appear in the menu."
echo "" 
echo "  --------------------------------------------------------------[0m"
echo ""

read -n1 -p " Press any key to quit this dialog ... "
