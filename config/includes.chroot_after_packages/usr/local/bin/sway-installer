#!/bin/bash
read -p "   [0;33mSway Compositor Installer[0m

   Sway comes pre-installed on Waydog, but if needing to reinstall
   or refresh the Sway config, this is the installer to use. A new
   ~/.config/sway.bak will be created if the config is present.
   
   [0;32m----------------------------------------------------------------

   Please press enter to install the Sway Compositor.

   ----------------------------------------------------------------[0m

   Or, close this terminal window to quit the install." ;
## Make sure of internet connection.
if : >/dev/tcp/8.8.8.8/53; then

sudo apt update
sudo apt install -y sway

if [ -e "$HOME/.config/sway" ]; then
   cp -fr "$HOME/.config/sway" "$HOME/.config/sway.bak"
   rm -fr "$HOME/.config/sway"
   cp -fr "/etc/skel/.config/sway" "$HOME/.config"
else
   cp -fr "/etc/skel/.config/sway" "$HOME/.config"
fi

LAYOUT=$(grep '^XKBLAYOUT=' /etc/default/keyboard | cut -d'"' -f2)
[[ -z "$LAYOUT" ]] && LAYOUT="us"
sed -i "s|xkb_layout \"[^\"]*\"|xkb_layout \"$LAYOUT\"|" "$HOME/.config/sway/config"

echo "   [0;32m--------------------------------------------------------[0m"
echo ""
echo "   [0;33mAll Finished![0m"
echo ""
echo "   [0;32mYou should find a new login entry for Sway.[0m"
echo ""
echo "   [0;32m--------------------------------------------------------[0m"
echo ""
else
echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
 echo ""
 echo "   [0;33mNo Internet connection. Please connect and try again.[0m"
 echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
echo ""
fi
read -n1 -p " Press any key to quit this dialog ... "
