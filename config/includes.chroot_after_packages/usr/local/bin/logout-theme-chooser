#!/bin/bash
# Created by sleekmason for Waydog 8 Jul 2026
# copies ld-logout from /usr/local/bin to ~/.local/bin for changes.

_check-exist(){
if ! test -f ~/.local/bin/ld-logout; then
if ! test -e ~/.local/bin; then
mkdir -p ~/.local/bin
cp -f "/usr/local/bin/ld-logout" "$HOME/.local/bin"
else
cp -f "/usr/local/bin/ld-logout" "$HOME/.local/bin"
fi
fi
}

notify-send "Yad still has a few issues in Wayland" "(dialog placement - titlebar exclusion)"

# Logout style and icons on/off.
_horzicons(){
bash -c "_check-exist"
if pgrep -x "ld-logout" >/dev/null 2>&1; then
pkill -P "$(pgrep -d, -x ld-logout)" 2>/dev/null
fi
sed -i 's/^varstyle.*/varstyle=horizontal-icons/g' "$HOME/.local/bin/ld-logout"
"$HOME/.local/bin/ld-logout" &
}
_horznoicons(){
bash -c "_check-exist"
if pgrep -x "ld-logout" >/dev/null 2>&1; then
pkill -P "$(pgrep -d, -x ld-logout)" 2>/dev/null
fi
sed -i 's/^varstyle.*/varstyle=horizontal-no-icons/g' "$HOME/.local/bin/ld-logout"
"$HOME/.local/bin/ld-logout" &
}
_verticons(){
bash -c "_check-exist"
if pgrep -x "ld-logout" >/dev/null 2>&1; then
pkill -P "$(pgrep -d, -x ld-logout)" 2>/dev/null
fi
sed -i 's/^varstyle.*/varstyle=vertical-icons/g' "$HOME/.local/bin/ld-logout"
"$HOME/.local/bin/ld-logout" &
}
_vertnoicons(){
bash -c "_check-exist"
if pgrep -x "ld-logout" >/dev/null 2>&1; then
pkill -P "$(pgrep -d, -x ld-logout)" 2>/dev/null
fi
sed -i 's/^varstyle.*/varstyle=vertical-no-icons/g' "$HOME/.local/bin/ld-logout"
"$HOME/.local/bin/ld-logout" &
}
