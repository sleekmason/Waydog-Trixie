#!/bin/bash
# Adwaita doesn't contain a gtk-4.0 folder, so clean up after selection.
/usr/bin/nwg-look &
PID=$!
LAST=""
while kill -0 "$PID" 2>/dev/null; do
    THEME=$(gsettings get org.gnome.desktop.interface gtk-theme | tr -d "'")
    if [[ "$THEME" != "$LAST" ]]; then
        GTK4_SRC="/usr/share/themes/${THEME}/gtk-4.0"
        GTK4_DEST="$HOME/.config/gtk-4.0"
        mkdir -p "$GTK4_DEST"
        if [[ "$THEME" == "Adwaita" || "$THEME" == "Adwaita-dark" ]]; then
            rm -rf "$GTK4_DEST"/*
        elif [[ -d "$GTK4_SRC" ]]; then
            rm -rf "$GTK4_DEST"/*
            [[ -f "$GTK4_SRC/gtk.css" ]] && ln -sf "$GTK4_SRC/gtk.css" "$GTK4_DEST/gtk.css"
            [[ -d "$GTK4_SRC/assets" ]]  && ln -sf "$GTK4_SRC/assets"  "$GTK4_DEST/assets"
        fi
        LAST="$THEME"
    fi
    sleep 0.2
done