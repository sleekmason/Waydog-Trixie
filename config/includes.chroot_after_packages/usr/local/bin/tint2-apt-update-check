#!/bin/bash
# Updater script for waydog.

if command -v x-terminal-emulator >/dev/null 2>&1; then
    REAL_TERM=$(basename "$(readlink -f "$(command -v x-terminal-emulator)")")
else
    echo "No terminal emulator found." >&2
    exit 1
fi

# Determine whether to use nala or apt.
if command -v nala >/dev/null 2>&1; then
    UPGRADE_CMD="nala"
else
    UPGRADE_CMD="apt"
fi

run_in_terminal() {
    SCRIPT="$1"
    case "$REAL_TERM" in
        ghostty)        x-terminal-emulator --title="Apt Upgrade" -e bash "$SCRIPT" ;;
        xfce4-terminal) x-terminal-emulator --hold --command "bash '$SCRIPT'" ;;
        alacritty)      x-terminal-emulator --title "Apt Upgrade" -e bash "$SCRIPT" ;;
        gnome-terminal) x-terminal-emulator -T "Apt Upgrade" -- bash "$SCRIPT" ;;
        foot)           x-terminal-emulator --title="Apt Upgrade" -e bash "$SCRIPT" ;;
        kitty)          x-terminal-emulator --title="Apt Upgrade" -e bash "$SCRIPT" ;;
        wezterm)        x-terminal-emulator start --title "Apt Upgrade" bash "$SCRIPT" ;;
        *)              x-terminal-emulator -e bash "$SCRIPT" ;;
    esac
}

# Count upgrades. (excluding held packages)
num_upgrades=$(( $(apt list --upgradable 2>/dev/null | wc -l) - $(apt-mark showhold | wc -l) - 1 ))
if (( num_upgrades == 0 )); then
    notify-send -i "/usr/share/icons/gnome/48x48/categories/applications-other.png" \
        -t 10000 --urgency low "No upgrades available."
    exit 0
fi
notify-send -i "/usr/share/icons/gnome/48x48/categories/applications-other.png" \
    -t 10000 --urgency low "$num_upgrades Upgrade(s) currently available."
# Temporary script to run in terminal.
TMP_SCRIPT=$(mktemp)
{
    echo 'echo ""'
    echo 'echo "[0;33mAvailable upgrades:[0m"'
    echo 'echo ""'
    if [[ "$UPGRADE_CMD" == "nala" ]]; then
        echo 'nala list --upgradeable'
    else
        echo 'APT_PAGER=cat apt list --upgradable'
    fi
    echo 'echo ""'
    echo 'echo "[0;32m-------------------------------------------------------[0m"'
    echo 'echo ""'
    echo 'held=$(apt-mark showhold)'
    echo 'if [[ -z "$held" ]]; then'
    echo '    echo "[0;34mHeld packages:[0m 0"'
    echo 'else'
    echo '    echo "[0;34mHeld packages:[0m $held"'
    echo 'fi'
    echo 'echo ""'
    echo 'echo "[0;33mPlease enter your password to upgrade, or exit to quit.[0m"'
    echo 'echo ""'
    if [[ "$UPGRADE_CMD" == "nala" ]]; then
        echo 'sudo nala upgrade'
    else
        echo 'sudo apt upgrade'
    fi
    echo 'bash'
} > "$TMP_SCRIPT"
chmod +x "$TMP_SCRIPT"
run_in_terminal "$TMP_SCRIPT"
