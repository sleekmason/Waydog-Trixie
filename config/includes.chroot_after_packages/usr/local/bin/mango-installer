#!/bin/bash
read -p "   [0;33mMangowm Compositor Installer[0m
 
   Mangowm is a modern wayland compositor based on wlroots & scenefx.
 
   [0;34mhttps://mangowm.github.io/[0m
   
   [0;32m------------------------------------------------------------------

   Please press enter to install the Mangowm compositor.

   ------------------------------------------------------------------[0m

   Or, close this terminal window to quit the install." ;
## Make sure of internet connection.
if : >/dev/tcp/8.8.8.8/53; then

echo ""
cd /tmp || exit
rm -f "mango-0.13.0.zip"
rm -fr "mango"
wget --prefer-family=IPv4 https://raw.githubusercontent.com/sleekmason/packages/master/mango-0.13.0.zip --show-progress -q || exit
unzip -q "mango-0.13.0.zip"
sudo apt update
sudo apt install -y \
  /tmp/mango/libscenefx-0.4_0.4.1-wd1_amd64.deb \
  /tmp/mango/libwlroots-0.19_0.19.3-wd1_amd64.deb \
  /tmp/mango/mangowm_0.13.0-wd1_amd64.deb || exit

if [ -e "$HOME/.config/mango" ]; then
   cp -fr "$HOME/.config/mango" "$HOME/.config/mango.bak"
   rm -fr "$HOME/.config/mango"
   cp -fr "/tmp/mango/mango" "$HOME/.config"
else
   cp -fr "/tmp/mango/mango" "$HOME/.config"
fi
mkdir -p "$HOME/.config/waybar/mango"
cp -f "/tmp/mango/config.jsonc" "$HOME/.config/waybar/mango"

LAYOUT=$(grep '^XKBLAYOUT=' /etc/default/keyboard | cut -d'"' -f2)
[[ -z "$LAYOUT" ]] && LAYOUT="us"
sed -i "s|^#\?xkb_rules_layout=.*|xkb_rules_layout=$LAYOUT|" "$HOME/.config/mango/config.conf"

echo "   [0;32m--------------------------------------------------------[0m"
echo ""
echo "   [0;33mAll Finished![0m"
echo ""
echo "   [0;32mYou should find a new login entry for Mangowm.[0m"
echo ""
echo "   [0;32m--------------------------------------------------------[0m"
echo ""
else
echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
 echo ""
 echo "   [0;33mNo Internet connection. Please connect and try again.[0m"
 echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
echo ""
fi
read -n1 -p " Press any key to quit this dialog ... "
