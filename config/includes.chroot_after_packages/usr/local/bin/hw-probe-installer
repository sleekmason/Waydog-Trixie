#!/bin/bash
echo ""
read -p "   [0;33mHw-Probe[0m

   The most comprehensive program to check your computer for issues.
   https://linux-hardware.org/ - Note that this will upload details
   of your system anonymously to the web.
   
   Hw-probe is a project to anonymously collect hardware details of 
   Linux-powered computers all over the world for helping people to 
   collaboratively debug hardware related issues, find drivers, and
   check for Linux-compatibility.

   If Hw-Probe is already installed, this script will simply run it 
   again. A link to the report will be available upon completion.
   
   [0;32m----------------------------------------------------------------
   
   Please press enter to install Hw-Probe or to re-run the program.
   
   ----------------------------------------------------------------[0m
      
   Or close this terminal window to quit the install." ;
   if : >/dev/tcp/8.8.8.8/53; then
echo ""
sudo apt update && sudo apt install --install-recommends -y hw-probe
echo ""
echo "[0;34m-------------------------------------------------------------------[0m"
echo ""
sudo -E hw-probe -all -upload
echo ""
echo "[0;33m-------------------------------------------------------------------[0m"
echo ""
echo "  [0;33mAll Done.  Right-click on the link above to access your report.[0m"
echo "  [0;33mHope the information found is useful.[0m"
echo ""
echo "[0;33m-------------------------------------------------------------------[0m"
echo ""
else
echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
 echo ""
 echo "   [0;33mNo Internet connection. Please connect and try again.[0m"
 echo ""
 echo "   [0;31m-----------------------------------------------------[0m"
echo ""
fi
read -n1 -p " Press any key to quit this dialog ... "
