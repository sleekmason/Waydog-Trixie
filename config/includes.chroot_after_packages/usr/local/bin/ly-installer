#!/bin/bash
set -euo pipefail
read -p "   [0;33mLy Display Manager Installer[0m

   This script will install the Ly display manager, A lightweight
   TUI (ncurses-like) display manager for Linux and BSD.
   
   For more information: 
   
   [0;34mhttps://codeberg.org/fairyglade/ly[0m
   
   [0;32m--------------------------------------------------------------
   
   Please press enter to install the Ly display manager.
   
   --------------------------------------------------------------[0m
      
   Or, close this terminal window to quit the install." ;
   if : >/dev/tcp/8.8.8.8/53; then

DEB="/tmp/ly_1.3.2-waydog_amd64.deb"

wget --prefer-family=IPv4 -q --show-progress \
    https://raw.githubusercontent.com/sleekmason/packages/master/ly_1.3.2-waydog_amd64.deb \
    -O "$DEB"

sudo apt-get update
sudo apt-get install -y "$DEB" || exit 1
sudo systemctl enable --force ly@tty1.service
sudo ln -sf /usr/lib/systemd/system/ly@.service /etc/systemd/system/display-manager.service
echo ""
echo " [0;32m-----------------------------------------[0m"
echo ""
echo " [0;32mDisplay manager set to Ly. Please reboot.[0m"
echo ""
echo " [0;32m-----------------------------------------[0m"
else
echo ""
 echo "   [0;31m-------------------------------------------------------"
 echo ""
 echo "   No Internet connection. Please connect and try again."
 echo ""
 echo "   -------------------------------------------------------[0m"
echo ""
fi
echo ""
read -n1 -p " Press any key to quit this dialog ... "
