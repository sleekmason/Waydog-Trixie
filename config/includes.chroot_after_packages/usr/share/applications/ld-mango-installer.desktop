#!/usr/bin/env xdg-open
[Desktop Entry]
Encoding=UTF-8
Type=Application
Exec=x-terminal-emulator -T 'Mango Compositor Installer' -e bash -c "mango-installer"
Name=Mango WM Installer
Icon=preferences-desktop-display
Terminal=false
GenericName=Mango Compositor Installer
Categories=ld-misc-tools;
Keywords=installer;
Comment=Mango Compositor Installer
