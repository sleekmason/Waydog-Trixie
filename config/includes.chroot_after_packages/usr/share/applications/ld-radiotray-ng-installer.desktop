#!/usr/bin/env xdg-open
[Desktop Entry]
Encoding=UTF-8
Type=Application
Exec=x-terminal-emulator -T 'Radiotray-ng Installer' -e bash -c "radiotray-ng-installer"
Name=Radiotray-ng Installer
Icon=audio-headphones
Terminal=true
GenericName=Radiotray-ng Installer
Categories=ld-misc-tools;
Keywords=installer;
Comment=Radiotray-ng Installer
